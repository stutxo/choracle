proof_fqdn = "proof.example.com"

# Parent bootstrap clones this repo/ref and builds the EIF on the parent.
source_repo_url = "https://github.com/stutxo/choracle.git"
source_ref      = "main"

# Optional: let Terraform create proof_fqdn in Route53.
route53_zone_id = "Z0123456789ABCDEFG"

# Optional hardening once you know the client IP range.
# allowed_https_cidr = "0.0.0.0/0"
